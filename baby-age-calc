<!doctype html>

<html lang="ko">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>아기 나이 계산기</title>
<style>
body{font-family:-apple-system;padding:20px;background:#f5f5f5}
.card{background:#fff;padding:20px;border-radius:16px}
input,button{width:100%;padding:12px;margin-top:10px;font-size:16px}
.result{margin-top:20px;font-size:20px;font-weight:bold}
</style>
</head>
<body>
<div class="card">
<h2>아기 나이 계산기</h2>
<input type="date" id="birth">
<button onclick="calc()">계산하기</button>

<div class="result" id="result"></div>
</div>

<script>
function calc(){
const b=new Date(document.getElementById('birth').value);
const now=new Date();
const days=Math.floor((now-b)/(1000*60*60*24));
const weeks=Math.floor(days/7);
const months=(now.getFullYear()-b.getFullYear())*12+(now.getMonth()-b.getMonth());

document.getElementById('result').innerHTML=
`생후 ${days}일<br>${weeks}주<br>${months}개월`;
}
</script>

</body>
</html>
